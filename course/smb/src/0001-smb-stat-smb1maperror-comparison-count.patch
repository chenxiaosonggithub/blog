From a481129facc030294bca947d45e6843b803608b2 Mon Sep 17 00:00:00 2001
From: ChenXiaoSong <chenxiaosong@chenxiaosong.com>
Date: Tue, 31 Mar 2026 07:53:44 +0000
Subject: [PATCH] smb: stat smb1maperror comparison count

Signed-off-by: ChenXiaoSong <chenxiaosong@chenxiaosong.com>
---
 fs/smb/client/smb1maperror.c      | 7 +++++++
 fs/smb/client/smb1maperror_test.c | 9 ++++++++-
 2 files changed, 15 insertions(+), 1 deletion(-)

diff --git a/fs/smb/client/smb1maperror.c b/fs/smb/client/smb1maperror.c
index d37bdc9135e4..fdbc127e7ebf 100644
--- a/fs/smb/client/smb1maperror.c
+++ b/fs/smb/client/smb1maperror.c
@@ -17,10 +17,15 @@
 #include "nterr.h"
 #include "cifs_debug.h"
 
+int cmp_count = 0;
+EXPORT_SYMBOL_FOR_MODULES(cmp_count, "smb1maperror_test");
+
 static __always_inline int smb1_posix_error_cmp(const void *_key, const void *_pivot)
 {
 	__u16 key = *(__u16 *)_key;
 	const struct smb_to_posix_error *pivot = _pivot;
+	cmp_count++;
+	mydebug_print("\n");
 
 	if (key < pivot->smb_err)
 		return -1;
@@ -53,6 +58,8 @@ static __always_inline int ntstatus_to_dos_cmp(const void *_key, const void *_pi
 {
 	__u32 key = *(__u32 *)_key;
 	const struct ntstatus_to_dos_err *pivot = _pivot;
+	cmp_count++;
+	mydebug_print("\n");
 
 	if (key < pivot->ntstatus)
 		return -1;
diff --git a/fs/smb/client/smb1maperror_test.c b/fs/smb/client/smb1maperror_test.c
index 92097b8b78d9..148da21ad679 100644
--- a/fs/smb/client/smb1maperror_test.c
+++ b/fs/smb/client/smb1maperror_test.c
@@ -12,6 +12,9 @@
 #include "smb1proto.h"
 #include "nterr.h"
 #include "smberr.h"
+#include "cifs_debug.h"
+
+extern int cmp_count;
 
 extern const struct ntstatus_to_dos_err *ntstatus_to_dos_map_test;
 extern unsigned int ntstatus_to_dos_num;
@@ -27,12 +30,16 @@ static void check_search_ ## __array(struct kunit *test)		\
 	unsigned int i;							\
 	const struct __struct_name *expect, *result;			\
 									\
-	for (i = 0; i < __num; i++) {					\
+	cmp_count = 0;							\
+	for (i = __num - 1; i < __num; i++) {				\
+		mydebug_print("\n");					\
 		expect = &__array ## _test[i];				\
 		result = search_ ## __array ## _test(expect->__field);	\
 		KUNIT_EXPECT_PTR_NE(test, NULL, result);		\
 		test_cmp_ ## __struct_name(test, expect, result);	\
 	}								\
+	printk("check_search_%s, %s:%d, cmp_count:%d\n",		\
+	       #__array, #__num, __num, cmp_count);			\
 }
 
 static void
-- 
2.52.0

